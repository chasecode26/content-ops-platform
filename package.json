{
  "name": "content-ops-platform",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "prisma": "^6.19.2"
  },
  "scripts": {
    "dev:api": "pnpm.cmd --dir apps/api-server start:dev",
    "dev:web": "pnpm.cmd --dir apps/web-admin dev",
    "dev:local": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run-local.ps1",
    "build:api": "pnpm.cmd --dir apps/api-server build",
    "build:web": "pnpm.cmd --dir apps/web-admin build",
    "db:generate": "apps\\api-server\\node_modules\\.bin\\prisma.cmd generate --schema prisma\\schema.prisma",
    "db:migrate": "apps\\api-server\\node_modules\\.bin\\prisma.cmd migrate dev --schema prisma\\schema.prisma",
    "db:deploy": "apps\\api-server\\node_modules\\.bin\\prisma.cmd migrate deploy --schema prisma\\schema.prisma",
    "db:seed": "node prisma\\seed.js"
  }
}
