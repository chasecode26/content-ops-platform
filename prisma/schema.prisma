generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  email           String?          @unique
  name            String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  channelAccounts ChannelAccount[]
  contentItems    ContentItem[]
}

model ChannelAccount {
  id                   String        @id @default(cuid())
  userId               String
  platform             PlatformCode
  name                 String
  status               AccountStatus @default(ACTIVE)
  credentialCiphertext String?
  browserProfilePath   String?
  meta                 Json?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  user                 User          @relation(fields: [userId], references: [id])
  draftRecords         DraftRecord[]
  publishJobs          PublishJob[]

  @@index([userId, platform])
}

model Theme {
  id             String        @id @default(cuid())
  code           String        @unique
  name           String
  targetPlatform PlatformCode
  version        Int           @default(1)
  tokens         Json
  template       Json
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  draftRecords   DraftRecord[]
}

model ContentItem {
  id           String            @id @default(cuid())
  userId       String
  title        String
  summary      String?
  slug         String            @unique
  sourceType   ContentSourceType
  canonicalUrl String?
  status       ContentStatus     @default(DRAFT)
  tags         String[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  user         User              @relation(fields: [userId], references: [id])
  versions     ContentVersion[]
  drafts       DraftRecord[]
  assets       MediaAsset[]
  publishJobs  PublishJob[]
  workflowRuns WorkflowRun[]

  @@index([userId, status, createdAt(sort: Desc)])
}

model ContentVersion {
  id             String      @id @default(cuid())
  contentItemId  String
  versionNo      Int
  title          String
  summary        String?
  markdownBody   String
  structuredBody Json?
  aiModel        String?
  promptSnapshot Json?
  changeSummary  String?
  createdAt      DateTime    @default(now())
  contentItem    ContentItem @relation(fields: [contentItemId], references: [id])

  @@unique([contentItemId, versionNo])
  @@index([contentItemId, versionNo(sort: Desc)])
}

model MediaAsset {
  id            String      @id @default(cuid())
  contentItemId String
  kind          AssetKind
  originalUrl   String?
  storagePath   String?
  mimeType      String?
  width         Int?
  height        Int?
  sizeBytes     Int?
  altText       String?
  meta          Json?
  createdAt     DateTime    @default(now())
  contentItem   ContentItem @relation(fields: [contentItemId], references: [id])

  @@index([contentItemId, kind])
}

model SourceTask {
  id           String            @id @default(cuid())
  sourceType   ContentSourceType
  inputPayload Json
  normalized   Json?
  status       WorkflowRunStatus @default(PENDING)
  errorMessage String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model DraftRecord {
  id               String         @id @default(cuid())
  contentItemId    String
  channelAccountId String
  themeId          String
  status           DraftStatus    @default(CREATED)
  platformDraftId  String?
  renderedHtml     String?
  previewUrl       String?
  platformPayload  Json?
  rawResponse      Json?
  errorMessage     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  channelAccount   ChannelAccount @relation(fields: [channelAccountId], references: [id])
  contentItem      ContentItem    @relation(fields: [contentItemId], references: [id])
  theme            Theme          @relation(fields: [themeId], references: [id])

  @@index([channelAccountId, status, createdAt(sort: Desc)])
}

model PublishJob {
  id               String           @id @default(cuid())
  contentItemId    String
  channelAccountId String
  status           PublishJobStatus @default(PENDING)
  scheduledAt      DateTime?
  startedAt        DateTime?
  finishedAt       DateTime?
  attemptCount     Int              @default(0)
  errorMessage     String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  platformPost     PlatformPost?
  channelAccount   ChannelAccount   @relation(fields: [channelAccountId], references: [id])
  contentItem      ContentItem      @relation(fields: [contentItemId], references: [id])

  @@index([channelAccountId, status, scheduledAt])
}

model PlatformPost {
  id             String       @id @default(cuid())
  publishJobId   String       @unique
  platform       PlatformCode
  platformPostId String
  postUrl        String?
  publishedAt    DateTime?
  metrics        Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  publishJob     PublishJob   @relation(fields: [publishJobId], references: [id])

  @@index([platform, platformPostId])
}

model WorkflowRun {
  id            String            @id @default(cuid())
  contentItemId String
  name          String
  status        WorkflowRunStatus @default(PENDING)
  stepCursor    String?
  inputPayload  Json?
  outputPayload Json?
  errorMessage  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  contentItem   ContentItem       @relation(fields: [contentItemId], references: [id])

  @@index([contentItemId, status, createdAt(sort: Desc)])
}

enum PlatformCode {
  WECHAT_OFFICIAL
  XIAOHONGSHU
  DOUYIN
  TOUTIAO
}

enum AccountStatus {
  ACTIVE
  EXPIRED
  DISABLED
}

enum ContentSourceType {
  MANUAL
  MARKDOWN
  URL
  RSS
  KEYWORD
}

enum ContentStatus {
  DRAFT
  READY_FOR_REVIEW
  APPROVED
  RENDERED
  PUBLISHED
  ARCHIVED
  FAILED
}

enum AssetKind {
  COVER
  INLINE_IMAGE
  GALLERY_IMAGE
  VIDEO
  ATTACHMENT
}

enum DraftStatus {
  CREATED
  UPDATED
  FAILED
  DELETED
}

enum PublishJobStatus {
  PENDING
  RENDERING
  WAITING_REVIEW
  READY_TO_PUSH
  PUSHING
  DRAFTED
  SCHEDULED
  PUBLISHED
  FAILED
  CANCELED
}

enum WorkflowRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}
